{
  "bsonType": "object",
  "required": [
    "uid",
    "plant_id",
    "growth_value",
    "stage"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ID，系统自动生成"
    },
    "uid": {
      "bsonType": "string",
      "title": "uni-id 用户ID"
    },
    "plant_id": {
      "bsonType": "string",
      "title": "花种ID",
      "foreignKey": "pf_plants._id"
    },
    "growth_value": {
      "bsonType": "int",
      "title": "当前成长值",
      "defaultValue": 0,
      "minimum": 0
    },
    "stage": {
      "bsonType": "string",
      "title": "当前阶段",
      "defaultValue": "seed",
      "enum": [
        {
          "text": "种子",
          "value": "seed"
        },
        {
          "text": "幼苗",
          "value": "sprout"
        },
        {
          "text": "开花",
          "value": "bloom"
        }
      ]
    },
    "health_score": {
      "bsonType": "int",
      "title": "健康度",
      "defaultValue": 100
    },
    "water_level": {
      "bsonType": "int",
      "title": "水分值(0-100)",
      "defaultValue": 60,
      "minimum": 0,
      "maximum": 100
    },
    "fertilizer_level": {
      "bsonType": "int",
      "title": "肥力值(0-100)",
      "defaultValue": 60,
      "minimum": 0,
      "maximum": 100
    },
    "last_action_date": {
      "bsonType": "string",
      "title": "最近行为日期",
      "description": "YYYY-MM-DD"
    },
    "exchange_status": {
      "bsonType": "string",
      "title": "兑换状态",
      "defaultValue": "none",
      "enum": [
        {
          "text": "未兑换",
          "value": "none"
        },
        {
          "text": "已兑换待发货",
          "value": "ordered"
        },
        {
          "text": "兑换处理中",
          "value": "ordering"
        },
        {
          "text": "已发货",
          "value": "shipped"
        },
        {
          "text": "已签收",
          "value": "received"
        }
      ]
    },
    "exchange_order_id": {
      "bsonType": "string",
      "title": "兑换订单ID"
    },
    "exchange_time": {
      "bsonType": "timestamp",
      "title": "兑换时间"
    },
    "create_time": {
      "bsonType": "timestamp",
      "description": "创建时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    },
    "update_time": {
      "bsonType": "timestamp",
      "description": "更新时间",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
