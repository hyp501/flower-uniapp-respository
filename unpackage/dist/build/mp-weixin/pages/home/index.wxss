.page{min-height:calc(100vh - 88rpx);position:relative;background:linear-gradient(180deg,#76c6ef,#abd8f2 34%,#c4e4bb 62%,#8eb257);padding:30rpx 24rpx 246rpx;box-sizing:border-box}.hero-header{position:relative;z-index:3}.hero-row{display:flex;justify-content:space-between;align-items:center;margin-top:8rpx}.profile-pill,.weather-pill{background:rgba(255,255,255,.84);border-radius:999rpx;box-shadow:0 8rpx 24rpx rgba(55,99,130,.16)}.profile-pill{display:flex;align-items:center;padding:10rpx 22rpx 10rpx 10rpx}.avatar{width:62rpx;height:62rpx;border-radius:50%;background:linear-gradient(180deg,#f8f6ff,#ecebfd);margin-right:14rpx;padding:4rpx;box-sizing:border-box}.avatar-inner{width:100%;height:100%;border-radius:50%;background:linear-gradient(180deg,#ffd4a3,#ffbe88);color:#7a4e2d;text-align:center;line-height:54rpx;font-size:28rpx;font-weight:700}.profile-name{font-size:32rpx;color:#3f4d52;font-weight:700}.profile-level{margin-top:4rpx;font-size:21rpx;color:#5f8f57}.profile-level:before{content:"";display:inline-block;width:12rpx;height:12rpx;border-radius:50%;background:#69b85a;margin-right:8rpx;vertical-align:middle}.weather-pill{padding:12rpx 20rpx;display:flex;align-items:center;gap:8rpx}.weather-icon{width:32rpx;height:32rpx;position:relative;margin-right:2rpx}.sun-core{width:22rpx;height:22rpx;border-radius:50%;background:#ffd35f;position:absolute;left:5rpx;top:5rpx}.sun-ring{width:32rpx;height:32rpx;border-radius:50%;border:3rpx solid rgba(255,211,95,.45);box-sizing:border-box;position:absolute;left:0;top:0}.weather-text{font-size:27rpx;color:#566772}.stats-card{margin-top:18rpx;border-radius:24rpx;background:rgba(255,255,255,.9);display:flex;align-items:center;justify-content:space-between;padding:18rpx 12rpx;box-shadow:0 8rpx 20rpx rgba(47,94,124,.16)}.stats-col{flex:1;text-align:center}.stats-card .stats-label{font-size:23rpx;color:#66757b}.stats-card .stats-value{margin-top:6rpx;font-size:44rpx;line-height:1.05;font-weight:700;color:#273a43}.stats-divider{width:2rpx;height:68rpx;background:#e5edf0}.notice-bubble{margin-top:14rpx;margin-left:auto;width:-webkit-fit-content;width:fit-content;max-width:78%;border-radius:999rpx;background:rgba(255,255,255,.9);color:#5b6170;font-size:27rpx;padding:10rpx 18rpx;box-shadow:0 8rpx 20rpx rgba(59,102,132,.16);display:flex;align-items:center}.notice-dot{width:14rpx;height:14rpx;border-radius:50%;background:#ff5f95;margin-right:10rpx}.garden-stage:before{content:"";position:absolute;bottom:0;right:22rpx;width:156rpx;height:156rpx;border-radius:50%;background:radial-gradient(circle,rgba(255,212,104,.95) 18%,rgba(255,255,255,.2) 60%,rgba(255,255,255,0) 78%);box-shadow:0 0 46rpx rgba(255,219,128,.56)}.ground-hill{position:absolute;left:-44rpx;right:-44rpx;bottom:0;height:640rpx;border-top-left-radius:20%;border-top-right-radius:20%;background:linear-gradient(180deg,#8aca54,#7f2b3a)}.plot{position:absolute;left:40rpx;right:40rpx;bottom:320rpx;height:122rpx;border-radius:26rpx;background:linear-gradient(180deg,#915c35,#754625);box-shadow:inset 0 -10rpx #512f19,0 8rpx 12rpx rgba(63,38,21,.2)}.empty-garden{height:100%;padding:16rpx 26rpx;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center}.empty-title{color:#f4e9db;font-size:30rpx;font-weight:700}.empty-desc{margin-top:10rpx;color:rgba(255,238,218,.9);font-size:22rpx;line-height:1.45}.empty-btn{margin-top:14rpx;padding:8rpx 20rpx;border-radius:999rpx;background:#f4d18d;color:#6f411d;font-size:22rpx;font-weight:700}.flower-point{position:absolute;bottom:76rpx;width:106rpx;transform:translate(-50%);transform-origin:center bottom;transition:transform .28s cubic-bezier(.22,1,.36,1)}.flower-point.active{transform:translate(-50%) scale(1.12)}.flower-point.pulse{animation:heroPulse .52s ease}.flower-image{width:106rpx;height:176rpx}.flower-name{margin-top:-16rpx;text-align:center;color:#f0f6ff;font-size:22rpx;text-shadow:0 2rpx 8rpx rgba(25,56,32,.5)}.float-score{position:absolute;left:50%;bottom:410rpx;transform:translate(-50%);z-index:5;color:#2a9a4d;font-size:42rpx;font-weight:700;text-shadow:0 4rpx 12rpx rgba(62,145,86,.3);animation:floatUp .9s ease forwards}.stage-up-tip{position:absolute;left:50%;bottom:490rpx;transform:translate(-50%);z-index:5;padding:8rpx 18rpx;border-radius:999rpx;background:linear-gradient(90deg,#ffd35d,#ffb347);color:#7a4e12;font-size:24rpx;font-weight:700;box-shadow:0 6rpx 16rpx rgba(255,191,87,.45);animation:stagePop 1.2s ease forwards}@keyframes heroPulse{0%{transform:scale(1)}45%{transform:scale(1.09)}to{transform:scale(1)}}@keyframes floatUp{0%{transform:translateY(10rpx) scale(.92);opacity:0}18%{opacity:1}to{transform:translateY(-72rpx) scale(1.06);opacity:0}}@keyframes stagePop{0%{opacity:0;transform:translate(-50%) translateY(12rpx) scale(.88)}20%{opacity:1;transform:translate(-50%) translateY(0) scale(1.04)}72%{opacity:1;transform:translate(-50%) translateY(0) scale(1)}to{opacity:0;transform:translate(-50%) translateY(-10rpx) scale(.96)}}
