.page{min-height:100vh;padding:28rpx;background:linear-gradient(180deg,#edf8ef,#f8fcf5 45%,#fff)}.hero-card,.card{background:var(--pf-color-surface);border-radius:var(--pf-radius-card);padding:30rpx;box-shadow:var(--pf-shadow-card);margin-bottom:22rpx}.hero-card{background:linear-gradient(145deg,#f2fff2,#fff 65%)}.hero-title{font-size:38rpx;font-weight:700;color:var(--pf-color-text-main)}.hero-subtitle{margin-top:12rpx;color:#6f8574;font-size:24rpx}.section-title{font-size:32rpx;font-weight:700;color:var(--pf-color-text-main);margin-bottom:18rpx}.score-grid{display:flex;gap:12rpx;flex-wrap:wrap}.score-item{width:calc((100% - 12rpx)/2);border-radius:16rpx;background:#f5fbf5;border:2rpx solid #deefe0;padding:16rpx 10rpx;text-align:center}.score-icon{font-size:42rpx}.score-name{margin-top:6rpx;font-size:24rpx;color:#4f6a55}.score-value{margin-top:8rpx;font-size:34rpx;font-weight:700;color:var(--pf-color-primary-dark)}.timeline{padding:8rpx 4rpx 0}.timeline-row{display:flex;align-items:center}.dot{width:18rpx;height:18rpx;border-radius:9rpx;background:#49b468}.line{flex:1;height:6rpx;border-radius:3rpx;background:#bfe6c9}.timeline-labels{margin-top:14rpx;display:flex;justify-content:space-between}.timeline-label{font-size:22rpx;color:#65816c}.highlight{margin-top:16rpx;border-radius:14rpx;background:#edf9ef;color:#2f7142;font-size:24rpx;padding:14rpx 16rpx}.rule-item{display:flex;align-items:flex-start;padding:14rpx 0}.rule-index{width:36rpx;font-size:26rpx;line-height:40rpx;color:var(--pf-color-primary-dark);font-weight:700}.rule-text{flex:1;font-size:26rpx;line-height:40rpx;color:#4a6351}.tip-card{border-radius:var(--pf-radius-card);background:#f3fbf2;color:#4b6d54;font-size:24rpx;padding:22rpx 24rpx;border:2rpx dashed #cde7d4}
