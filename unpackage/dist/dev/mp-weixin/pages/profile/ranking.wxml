<view class="page"><view wx:if="{{a}}" class="sticky-me"><view class="{{['me-card', 'highlight']}}"><view class="me-rank">#{{b}}</view><view class="me-info"><view class="me-name">{{c}}</view><view class="me-sub">我的累计成长值</view></view><view class="me-score">{{d}}</view></view></view><view class="card list-card"><view class="panel-head"><view class="panel-title-wrap"><view class="panel-dot"></view><view class="panel-title">成长值排行榜</view></view><view class="panel-meta">TOP {{e}}</view></view><view wx:if="{{f}}" class="empty">加载中...</view><view wx:elif="{{g}}" class="empty">暂无排行数据，快去花园积累成长值吧</view><view wx:else class="rank-list"><view wx:for="{{h}}" wx:for-item="item" wx:key="g" class="{{['rank-row', item.h && 'me', item.i && 'top3']}}"><view class="rank-num"><text wx:if="{{item.a}}" class="medal">🥇</text><text wx:elif="{{item.b}}" class="medal">🥈</text><text wx:elif="{{item.c}}" class="medal">🥉</text><text wx:else class="rank-text">{{item.d}}</text></view><view class="rank-name">{{item.e}}</view><view class="rank-growth">{{item.f}}</view></view></view></view><view class="tip">按累计成长值从高到低排序，相同分值按注册先后。</view></view>