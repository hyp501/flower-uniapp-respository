<view class="page"><view class="header-card"><view class="title">成长日志</view><view class="subtitle">记录你照料花朵的每一步</view></view><view wx:if="{{a}}" class="empty-card">暂无行为记录</view><view wx:for="{{b}}" wx:for-item="item" wx:key="d" class="item"><view class="top"><view class="action-chip">{{item.a}}</view><text class="growth">+{{item.b}}</text></view><view class="date">{{item.c}}</view></view><view wx:if="{{c}}" class="load-more" bindtap="{{d}}">加载更多</view></view>